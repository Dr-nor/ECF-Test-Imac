{# templates/admin/commandes.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gestion Commandes — Admin — Vite & Gourmand{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">
                <i class="bi bi-list-check text-primary me-2"></i>Gestion des commandes
            </h1>
            <p class="text-muted mb-0">{{ commandes|length }} commande{% if commandes|length > 1 %}s{% endif %} au total</p>
        </div>
        <a href="{{ path('admin_dashboard') }}" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left me-1"></i>Dashboard
        </a>
    </div>

    {% if commandes is empty %}
        <div class="text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size:4rem;"></i>
            <p class="text-muted mt-3 fs-5">Aucune commande pour le moment.</p>
        </div>
    {% else %}
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Numéro</th>
                            <th>Client</th>
                            <th>Menu</th>
                            <th>Personnes</th>
                            <th>Prestation</th>
                            <th>Total</th>
                            <th>Statut</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for commande in commandes %}
                        <tr>
                            <td><span class="fw-bold text-primary small">{{ commande.numeroCommande }}</span></td>
                            <td>
                                <div class="fw-semibold">{{ commande.user.prenom }} {{ commande.user.nom }}</div>
                                <div class="text-muted small">{{ commande.user.email }}</div>
                            </td>
                            <td>{{ commande.menu.titre }}</td>
                            <td>
                                {{ commande.nombrePersonnes }}
                                {% if commande.nombrePersonnes >= 5 %}
                                    <span class="badge bg-success ms-1">-10%</span>
                                {% endif %}
                            </td>
                            <td>{{ commande.datePrestation|date('d/m/Y') }}</td>
                            <td class="fw-bold text-primary">{{ commande.prixTotal|number_format(2, ',', ' ') }} €</td>
                            <td>
                                {% set statut = commande.statut %}
                                {% if statut == 'en_attente' %}
                                    <span class="badge bg-warning text-dark">En attente</span>
                                {% elseif statut == 'confirmée' %}
                                    <span class="badge bg-primary">Confirmée</span>
                                {% elseif statut == 'livrée' %}
                                    <span class="badge bg-success">Livrée</span>
                                {% elseif statut == 'annulée' %}
                                    <span class="badge bg-danger">Annulée</span>
                                {% endif %}
                            </td>
                            <td>
                                <form method="POST" action="{{ path('admin_commande_statut', {id: commande.id}) }}">
                                    <div class="input-group input-group-sm">
                                        <select name="statut" class="form-select form-select-sm">
                                            <option value="en_attente" {% if commande.statut == 'en_attente' %}selected{% endif %}>En attente</option>
                                            <option value="confirmée"  {% if commande.statut == 'confirmée'  %}selected{% endif %}>Confirmée</option>
                                            <option value="livrée"     {% if commande.statut == 'livrée'     %}selected{% endif %}>Livrée</option>
                                            <option value="annulée"    {% if commande.statut == 'annulée'    %}selected{% endif %}>Annulée</option>
                                        </select>
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            <i class="bi bi-check"></i>
                                        </button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

</div>
{% endblock %}
