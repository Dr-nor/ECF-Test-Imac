{# templates/base.html.twig
   ECF DWWM 2026 — Vite & Gourmand
   Layout principal Bootstrap 5 + charte #1A6BAD
#}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Vite & Gourmand — Traiteur Bordeaux{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Julie & José — Traiteur événementiel Bordeaux depuis 2015{% endblock %}">

    {# Bootstrap 5.3 CDN #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous">

    {# Bootstrap Icons 1.11 #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet">

    {# CSS Custom Charte Graphique #}
    <link rel="stylesheet" href="{{ asset('css/vite-gourmand.css') }}">

    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ======= NAVBAR ======= #}
<nav class="navbar navbar-expand-lg navbar-vg sticky-top">
    <div class="container">
        {# Logo / Brand #}
        <a class="navbar-brand" href="{{ path('app_') }}">
            <i class="bi bi-egg-fried me-1"></i>
            Vite <span>&</span> Gourmand
        </a>

        {# Toggler mobile #}
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarMain"
                aria-controls="navbarMain"
                aria-expanded="false"
                aria-label="Menu">
            <span class="navbar-toggler-icon"></span>
        </button>

        {# Liens de navigation #}
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto ms-3 gap-1">
                <li class="nav-item">
                    <a class="nav-link {% if app.request.get('_route') == 'app_' %}active{% endif %}"
                       href="{{ path('app_') }}">
                        <i class="bi bi-house me-1"></i>Accueil
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.get('_route') starts with 'menu_' %}active{% endif %}"
                       href="{{ path('menu_index') }}">
                        <i class="bi bi-grid me-1"></i>Nos Menus
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-telephone me-1"></i>Contact
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-clock me-1"></i>Horaires
                    </a>
                </li>
            </ul>

            {# Boutons droite #}
            <div class="d-flex align-items-center gap-2">
                {% if is_granted('ROLE_USER') %}
                    <span class="text-white-50 small me-1">
                        <i class="bi bi-person-circle me-1"></i>{{ app.user.prenom }}
                    </span>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin_dashboard') }}" class="btn-connexion btn btn-sm">
                            <i class="bi bi-shield me-1"></i>Admin
                        </a>
                    {% endif %}
                    <a href="{{ path('app_logout') }}" class="btn-connexion btn btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn-connexion btn btn-sm">
                        <i class="bi bi-person me-1"></i>Connexion
                    </a>
                {% endif %}
                <a href="{{ path('menu_index') }}" class="btn-commander btn btn-sm">
                    <i class="bi bi-cart me-1"></i>Commander
                </a>
            </div>
        </div>
    </div>
</nav>

{# ======= FLASH MESSAGES ======= #}
{% set flashes = app.flashes %}
{% if flashes %}
<div class="container flash-container">
    {% for label, messages in flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show mt-2" role="alert">
                {% if label == 'success' %}<i class="bi bi-check-circle me-2"></i>{% endif %}
                {% if label == 'danger'  %}<i class="bi bi-exclamation-circle me-2"></i>{% endif %}
                {% if label == 'warning' %}<i class="bi bi-exclamation-triangle me-2"></i>{% endif %}
                {% if label == 'info'    %}<i class="bi bi-info-circle me-2"></i>{% endif %}
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>
{% endif %}

{# ======= CONTENU PRINCIPAL ======= #}
{% block body %}{% endblock %}

{# ======= FOOTER ======= #}
<footer class="footer-vg">
    <div class="container">
        <div class="row g-4">
            {# Colonne 1 — Brand #}
            <div class="col-12 col-md-4 col-lg-3">
                <span class="footer-brand">
                    <i class="bi bi-egg-fried me-2"></i>Vite & Gourmand
                </span>
                <p class="footer-tagline">
                    Le traiteur événementiel de référence à Bordeaux.
                    Julie & José à votre service depuis 2015.
                </p>
            </div>

            {# Colonne 2 — Navigation #}
            <div class="col-6 col-md-2">
                <h6>Navigation</h6>
                <ul>
                    <li><a href="{{ path('app_') }}">Accueil</a></li>
                    <li><a href="{{ path('menu_index') }}">Nos menus</a></li>
                    <li><a href="#">Commandes</a></li>
                    <li><a href="#">Contact</a></li>
                </ul>
            </div>

            {# Colonne 3 — Horaires #}
            <div class="col-6 col-md-3">
                <h6>Horaires</h6>
                <ul>
                    <li>Lun–Ven : 09h–19h</li>
                    <li>Sam : 10h–18h</li>
                    <li class="horaire-ferme">Dim : Fermé</li>
                </ul>
            </div>

            {# Colonne 4 — Contact #}
            <div class="col-12 col-md-3 footer-contact">
                <h6>Contact</h6>
                <ul>
                    <li><a href="mailto:julie.jose@vite-gourmand.fr">julie.jose@vite-gourmand.fr</a></li>
                    <li>05 56 XX XX XX</li>
                    <li>Bordeaux, 33000</li>
                </ul>
            </div>
        </div>

        <hr class="footer-divider">

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center footer-bottom">
            <span>© 2026 Vite & Gourmand — Noureddine Zerrouki — ECF DWWM</span>
            <div class="d-flex gap-3 mt-2 mt-md-0">
                <a href="#">Mentions légales</a>
                <a href="#">Confidentialité</a>
            </div>
        </div>
    </div>
</footer>

{# Bootstrap 5 JS #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmLLXEewCs0BHWa/t1tDT6KnEi/y"
        crossorigin="anonymous"></script>

{% block javascripts %}{% endblock %}
</body>
</html>
