{% extends 'base.html.twig' %}

{% block title %}Connexion — Vite & Gourmand{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-5">

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <div class="text-center mb-4">
                        <div style="font-size:2.5rem;">🍽️</div>
                        <h1 class="h4 mt-2" style="color:var(--primary);">Connexion</h1>
                        <p class="text-muted small">Espace réservé à l'équipe Vite & Gourmand</p>
                    </div>

                    {% if error %}
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form method="post" action="{{ path('app_login') }}">
                        <div class="mb-3">
                            <label for="inputEmail" class="form-label fw-semibold">
                                <i class="bi bi-envelope me-1"></i>Email
                            </label>
                            <input type="email"
                                   id="inputEmail"
                                   name="_username"
                                   class="form-control"
                                   value="{{ last_username }}"
                                   autocomplete="email"
                                   required
                                   autofocus>
                        </div>

                        <div class="mb-4">
                            <label for="inputPassword" class="form-label fw-semibold">
                                <i class="bi bi-lock me-1"></i>Mot de passe
                            </label>
                            <input type="password"
                                   id="inputPassword"
                                   name="_password"
                                   class="form-control"
                                   autocomplete="current-password"
                                   required>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button type="submit"
                                class="btn w-100"
                                style="background:var(--primary);color:#fff;padding:.75rem;">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                        </button>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}