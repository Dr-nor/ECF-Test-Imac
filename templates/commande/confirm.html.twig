{# templates/commande/confirm.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Commande confirmée — Vite & Gourmand{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">

            <div class="text-center mb-5">
                <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:80px;height:80px;">
                    <i class="bi bi-check-lg text-success" style="font-size:2.5rem;"></i>
                </div>
                <h1 class="h3 fw-bold">Commande confirmée !</h1>
                <p class="text-muted">Un email de confirmation vous a été envoyé à
                    <strong>{{ app.user.email }}</strong>
                </p>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-receipt me-2"></i>
                        Récapitulatif — {{ commande.numeroCommande }}
                    </h5>
                </div>
                <div class="card-body p-4">
                    <dl class="row mb-0">
                        <dt class="col-6 text-muted">Menu</dt>
                        <dd class="col-6 fw-semibold">{{ menu.titre }}</dd>

                        <dt class="col-6 text-muted">Nombre de personnes</dt>
                        <dd class="col-6">{{ commande.nombrePersonnes }}</dd>

                        <dt class="col-6 text-muted">Date de prestation</dt>
                        <dd class="col-6">{{ commande.datePrestation|date('d/m/Y') }}</dd>

                        <dt class="col-6 text-muted">Adresse de livraison</dt>
                        <dd class="col-6">{{ commande.adresseLivraison }}</dd>

                        <dt class="col-6 text-muted">Prix de base</dt>
                        <dd class="col-6">{{ prixBase|number_format(2, ',', ' ') }} €</dd>

                        {% if aReduction %}
                        <dt class="col-6 text-success">
                            <i class="bi bi-tag me-1"></i>Réduction -10%
                            <span class="badge bg-success ms-1">≥ 5 pers.</span>
                        </dt>
                        <dd class="col-6 text-success fw-semibold">
                            - {{ montantReduc|number_format(2, ',', ' ') }} €
                        </dd>
                        {% endif %}

                        <hr class="my-2">

                        <dt class="col-6 fw-bold fs-5">Total payé</dt>
                        <dd class="col-6 fw-bold fs-5 text-primary">
                            {{ commande.prixTotal|number_format(2, ',', ' ') }} €
                        </dd>

                        <dt class="col-6 text-muted">Statut</dt>
                        <dd class="col-6">
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-hourglass me-1"></i>{{ commande.statut }}
                            </span>
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-3">
                <a href="{{ path('cmd_history') }}" class="btn btn-primary flex-fill">
                    <i class="bi bi-list-ul me-2"></i>Mes commandes
                </a>
                <a href="{{ path('menu_index') }}" class="btn btn-outline-primary flex-fill">
                    <i class="bi bi-grid me-2"></i>Voir d'autres menus
                </a>
                <a href="{{ path('app_') }}" class="btn btn-outline-secondary flex-fill">
                    <i class="bi bi-house me-2"></i>Accueil
                </a>
            </div>

        </div>
    </div>
</div>
{% endblock %}
